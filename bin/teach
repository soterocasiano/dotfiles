#!/usr/bin/env sh

# Generates a lesson via $TEACHING_DIR/scripts/generate_lesson.py.
# All arguments are forwarded as-is, e.g.:
#   teach --topic "Introduction to Recursion" \
#       --audience "High school students, no prior programming experience" \
#       --depth "Quick overview" \
#       --goal "Understand recursion and write a simple recursive function" \
#       --prior-knowledge "Basic Python syntax, loops"
USAGE='teach --topic <topic> [--audience <audience>] [--depth <depth>] [--goal <goal>] [--prior-knowledge <prior-knowledge>] [--model <model>] [--output <path>]'

# Defaults used for any flag not passed in.
audience="General audience, no prior experience assumed"
depth="Quick overview"
prior_knowledge="None"
goal="Understand the fundamentals of the topic"
topic=""

while [ $# -gt 0 ]; do
    case "$1" in
        --topic) topic="$2"; shift 2 ;;
        --audience) audience="$2"; shift 2 ;;
        --depth) depth="$2"; shift 2 ;;
        --goal) goal="$2"; shift 2 ;;
        --prior-knowledge) prior_knowledge="$2"; shift 2 ;;
        *) echo "Unknown argument: $1"; echo "$USAGE"; exit 1 ;;
    esac
done

if [ -z "$topic" ]; then
    echo "Please provide a --topic"
    echo "$USAGE"
    exit 1
fi

if [ -z "$TEACHING_DIR" ]; then
    echo "Please define your TEACHING_DIR"
    exit 3
fi

if [ ! -d "$TEACHING_DIR" ]; then
    echo "TEACHING_DIR ($TEACHING_DIR) does not exist"
    exit 3
fi

. "$TEACHING_DIR/.venv/bin/activate"

# --model and --output are left to generate_lesson.py's own defaults
# unless explicitly provided here.
set -- "$TEACHING_DIR/scripts/generate_lesson.py" \
    --topic "$topic" \
    --audience "$audience" \
    --depth "$depth" \
    --goal "$goal" \
    --prior-knowledge "$prior_knowledge"

python "$@"

